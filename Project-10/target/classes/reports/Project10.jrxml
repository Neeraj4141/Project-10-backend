	<queryString language="SQL">
		<![CDATA[SELECT id, roll_no, student_id, name, physics, chemistry, maths, (physics + chemistry + maths) AS total FROM st_marksheet WHERE physics >= 33 AND chemistry >= 33 AND maths >= 33 ORDER BY total DESC;]]>
	</queryString>
